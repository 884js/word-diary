{
  "expo": {
    "name": "一言日記",
    "slug": "word-diary",
    "version": "1.1.1",
    "orientation": "portrait",
    "scheme": "worddiary",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.uki884.worddiary",
      "buildNumber": "14",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.uki884.worddiary"
        ]
      }
    },
    "android": {
      "package": "com.uki884.worddiary",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F3"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF8F3",
          "resizeMode": "contain"
        }
      ],
      "expo-dev-client",
      "react-native-edge-to-edge",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-sqlite",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2fd086c-7232-41d1-bee7-815da963b330"
      }
    },
    "owner": "uki884"
  }
}
