{
  "expo": {
    "name": "一言日記",
    "slug": "word-diary",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "worddiary",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.uki884.worddiary",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": ["ja"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.uki884.worddiary",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F3"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF8F3",
          "resizeMode": "contain"
        }
      ],
      "expo-dev-client",
      "react-native-edge-to-edge",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true,
      "reactCompiler": true
    }
  }
}
